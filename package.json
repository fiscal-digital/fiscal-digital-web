{
  "name": "@fiscal-digital/web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/generate-brand-theme.mjs",
    "build": "open-next build",
    "predev": "node scripts/generate-brand-theme.mjs",
    "type-check": "tsc --noEmit",
    "brand:theme": "node scripts/generate-brand-theme.mjs",
    "lint:copy": "node scripts/lint-copy.mjs",
    "pretest": "npm run lint:copy",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:codegen": "playwright codegen https://fiscaldigital.org/pt-br/alertas/",
    "test:e2e:full": "PLAYWRIGHT_FULL_MATRIX=1 playwright test"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.0",
    "next": "^16.2.9",
    "next-intl": "^4.13.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@opennextjs/aws": "^4.0.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.2.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.8"
  }
}
